{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.yuruimukun.com"
        }
      ],
      "destination": "https://yuruimukun.com/:path*",
      "permanent": true
    },
    {
      "source": "/public/ninja.html",
      "destination": "/public/tracks/ninja.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/config/top-arrival-bgm.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
